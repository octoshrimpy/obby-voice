{
	"name": "obby-voice",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"description": "Quick speech-to-text into a daily Inbox note via Whisper WASM, with mobile command.",
	"main": "main.js",
	"scripts": {
		"dev": "esbuild main.ts --bundle --outfile=main.js --format=cjs --platform=node --external:obsidian --watch",
		"build": "esbuild main.ts --bundle --minify --outfile=main.js --format=cjs --platform=node --external:obsidian",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [],
	"author": "octoshrimpy",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@typescript-eslint/eslint-plugin": "^8.39.1",
		"@typescript-eslint/parser": "^8.39.1",
		"builtin-modules": "3.3.0",
		"esbuild": "^0.25.9",
		"eslint": "^9.33.0",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.4.0"
	},
	"dependencies": {
		"@remotion/whisper-web": "^4.0.0"
	}
}
